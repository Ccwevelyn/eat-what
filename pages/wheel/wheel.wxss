/* pages/wheel/wheel.wxss */
.container {
  padding: 32rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
}

.wheel-wrap {
  position: relative;
  width: 560rpx;
  height: 560rpx;
  margin: 40rpx auto;
  border-radius: 50%;
}

.wheel-outer {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: hidden;
  transition: transform 4s cubic-bezier(0.2, 0.8, 0.3, 1);
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.15);
  border: 6rpx solid #5A3D99;
}

.pointer {
  position: absolute;
  left: 50%;
  top: -8rpx;
  margin-left: -24rpx;
  z-index: 20;
  color: #333;
  font-size: 36rpx;
  text-align: center;
  line-height: 1;
}


.wheel-inner {
  width: 100%;
  height: 100%;
  position: relative;
  border-radius: 50%;
}

.segment {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 50%;
  height: 50%;
  transform-origin: 0% 0%;
  clip-path: polygon(0 0, 100% 0, 70.7% 70.7%);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 16rpx;
  padding-left: 12rpx;
  box-sizing: border-box;
}

.segment-0 { transform: rotate(0deg); background: #6B4EAA; }
.segment-1 { transform: rotate(45deg); background: #7C5CBF; }
.segment-2 { transform: rotate(90deg); background: #8B6FC7; }
.segment-3 { transform: rotate(135deg); background: #6B4EAA; }
.segment-4 { transform: rotate(180deg); background: #5A3D99; }
.segment-5 { transform: rotate(225deg); background: #7C5CBF; }
.segment-6 { transform: rotate(270deg); background: #8B6FC7; }
.segment-7 { transform: rotate(315deg); background: #5A3D99; }

.segment-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.5);
  white-space: nowrap;
  font-family: "KaiTi", "楷体", serif;
}

.segment-0 .segment-text { transform: rotate(-22.5deg); }
.segment-1 .segment-text { transform: rotate(-67.5deg); }
.segment-2 .segment-text { transform: rotate(-112.5deg); }
.segment-3 .segment-text { transform: rotate(-157.5deg); }
.segment-4 .segment-text { transform: rotate(-202.5deg); }
.segment-5 .segment-text { transform: rotate(-247.5deg); }
.segment-6 .segment-text { transform: rotate(-292.5deg); }
.segment-7 .segment-text { transform: rotate(-337.5deg); }

.wheel-center {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 160rpx;
  height: 160rpx;
  margin-left: -80rpx;
  margin-top: -80rpx;
  background: #5A3D99;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
  z-index: 10;
}

.center-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.section.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-top: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.cuisine-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #6B4EAA;
  margin-bottom: 8rpx;
}

.cuisine-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.restaurant-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rest-item {
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.rest-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.rest-address, .rest-distance {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 6rpx;
}

.nav-links {
  margin-top: 48rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

