<!--pages/wheel/wheel.wxml - 第二页：菜系转盘 -->
<view class="lang-switch" bindtap="switchLang">{{lang === 'zh' ? t.langEn : t.langZh}}</view>
<view class="container">
  <view class="wheel-wrap">
    <view class="pointer">▼</view>
    <view class="wheel-outer" style="transform: rotate({{ wheelRotation }}deg);">
      <view class="wheel-inner">
        <view class="segment segment-0"><text class="segment-text">茶餐厅</text></view>
        <view class="segment segment-1"><text class="segment-text">韩餐</text></view>
        <view class="segment segment-2"><text class="segment-text">日料</text></view>
        <view class="segment segment-3"><text class="segment-text">西餐</text></view>
        <view class="segment segment-4"><text class="segment-text">粤菜</text></view>
        <view class="segment segment-5"><text class="segment-text">川菜</text></view>
        <view class="segment segment-6"><text class="segment-text">东南亚</text></view>
        <view class="segment segment-7"><text class="segment-text">南亚</text></view>
        <view class="segment segment-8"><text class="segment-text">火锅</text></view>
      </view>
    </view>
    <view class="wheel-center" bindtap="onSpinTap">
      <text class="center-text">{{ spinning ? (t.wheelSpinning || '转盘中…') : (t.wheelSpin || '点我转') }}</text>
    </view>
  </view>

  <view wx:if="{{ selectedCuisine }}" class="section card">
    <text class="cuisine-title">{{t.wheelCuisineTodayPrefix}}{{ selectedCuisine }}</text>
    <text class="cuisine-desc">{{t.wheelCuisineDesc}}</text>
    <view class="restaurant-list">
      <view class="rest-item" wx:for="{{ restaurantList }}" wx:key="name" wx:if="{{ item.name !== '未知' }}">
        <text class="rest-name">{{ item.name }}</text>
        <text wx:if="{{ item.region && item.region !== '未知' }}" class="rest-address-label">{{t.regionLabel}}</text>
        <text wx:if="{{ item.region && item.region !== '未知' }}" class="rest-address">{{ item.region }}</text>
        <block wx:if="{{ item.address && item.address !== '未知' }}">
          <text class="rest-address-label">{{t.addressLabel}}</text>
          <text class="rest-address">{{ item.address }}</text>
        </block>
        <text class="rest-distance">{{t.distanceAboutBefore}}{{ item.distance }}{{t.distanceAboutAfter}}</text>
      </view>
    </view>
  </view>

</view>
