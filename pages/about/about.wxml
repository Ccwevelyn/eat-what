<!--pages/about/about.wxml - 第三页：声明与鸣谢 -->
<view class="lang-switch" bindtap="switchLang">{{lang === 'zh' ? t.langEn : t.langZh}}</view>
<view class="container">
  <view class="section card">
    <text class="title">{{t.aboutDataTitle}}</text>
    <text class="body">{{t.aboutDataBody}}</text>
  </view>

  <view class="section card">
    <text class="title">{{t.aboutNonProfitTitle}}</text>
    <text class="body">{{t.aboutNonProfitBody}}</text>
  </view>

  <view class="section card thanks">
    <text class="title">{{t.aboutThanksTitle}}</text>
    <text class="body">{{t.aboutThanksBody}}<text class="name">{{t.aboutThanksName}}</text>{{t.aboutThanksSuffix}}</text>
  </view>

  <view class="section card">
    <text class="title">{{t.aboutDisclaimerTitle}}</text>
    <text class="body">{{t.aboutDisclaimerBody}}</text>
  </view>

  <view class="section card contact">
    <text class="title">{{t.aboutContactTitle}}</text>
    <text class="body">{{t.aboutContactBody}}</text>
    <text class="email" selectable>ccwevelyncambridge@outlook.com</text>
  </view>

</view>
