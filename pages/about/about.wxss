/* pages/about/about.wxss */
.lang-switch {
  position: fixed;
  top: 24rpx;
  right: 24rpx;
  z-index: 100;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #6B4EAA;
  background: rgba(255,255,255,0.95);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}
.container {
  padding: 32rpx;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.section {
  margin-bottom: 24rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #6B4EAA;
  margin-bottom: 16rpx;
}

.body {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
}

.name {
  font-weight: 600;
  color: #333;
}

.thanks .body {
  font-size: 28rpx;
}

.contact .email {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #6B4EAA;
  word-break: break-all;
}
