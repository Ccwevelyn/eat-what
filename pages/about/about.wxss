/* pages/about/about.wxss */
.container {
  padding: 32rpx;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.section {
  margin-bottom: 24rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #FF6B35;
  margin-bottom: 16rpx;
}

.body {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  display: block;
}

.name {
  font-weight: 600;
  color: #333;
}

.thanks .body {
  font-size: 28rpx;
}

.contact .email {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #FF6B35;
  word-break: break-all;
}

.nav-links {
  margin-top: 48rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.link {
  color: #FF6B35;
  font-size: 28rpx;
}
