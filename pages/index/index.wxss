/* pages/index/index.wxss */
.container {
  padding: 32rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
}

.section {
  margin-bottom: 32rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  font-family: "YouYuan", "幼圆", "华文圆体", sans-serif;
}

.desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
  display: block;
}

.btn {
  border-radius: 48rpx;
  font-size: 30rpx;
}

.btn.primary {
  background: linear-gradient(135deg, #6B4EAA 0%, #8B6FC7 100%);
  color: #fff;
  border: none;
}

.btn.primary.big {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.btn.primary[disabled] {
  background: #ccc;
  color: #999;
}

.location-status {
  margin-bottom: 16rpx;
}
.status-on {
  color: #52c41a;
  font-size: 28rpx;
}
.status-off {
  color: #666;
  font-size: 28rpx;
}
.location-ok {
  color: #52c41a;
  font-size: 28rpx;
}
.location-debug {
  display: block;
  margin-top: 12rpx;
  color: #6B4EAA;
  font-size: 24rpx;
}
.location-debug.coords {
  color: #888;
  font-size: 22rpx;
}

.slider-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 24rpx 0;
}

.slider {
  flex: 1;
}

.slider-label {
  font-size: 24rpx;
  color: #666;
}

.distance-hint {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-top: 16rpx;
  text-align: center;
}

.result {
  border: 2rpx solid #6B4EAA;
}

.result-title {
  display: block;
  font-size: 28rpx;
  color: #6B4EAA;
  margin-bottom: 16rpx;
}

.result-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.result-cuisine {
  display: block;
  font-size: 26rpx;
  color: #6B4EAA;
  margin-bottom: 8rpx;
}

.result-address-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  margin-bottom: 4rpx;
}

.result-address, .result-distance {
  display: block;
  font-size: 26rpx;
  color: #333;
}

.nav-links {
  margin-top: 48rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.link {
  color: #6B4EAA;
  font-size: 28rpx;
}
