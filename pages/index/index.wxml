<!--pages/index/index.wxml - 第一页：附近随机餐厅 -->
<view class="lang-switch" bindtap="switchLang">{{lang === 'zh' ? t.langEn : t.langZh}}</view>
<view class="container">
  <view class="section card">
    <text class="title">{{t.locationTitle}}</text>
    <text class="desc">{{t.locationDesc}}</text>
    <view class="location-status">
      <text wx:if="{{locationAuthorized}}" class="status-on">{{t.locationOn}}</text>
      <text wx:else class="status-off">{{t.locationOff}}</text>
    </view>
    <button wx:if="{{!hasLocation}}" class="btn primary" bindtap="requestLocation">{{t.btnOpenLocation}}</button>
    <block wx:else>
      <text class="location-ok">{{t.locationReady}}</text>
      <text wx:if="{{locationLabel}}" class="location-debug">{{t.locationLabel}}{{ locationLabel }}</text>
      <text wx:if="{{locationCoords}}" class="location-debug coords">{{ locationCoords }}</text>
    </block>
  </view>

  <view class="section card">
    <text class="title">{{t.distanceTitle}}</text>
    <view class="slider-wrap">
      <text class="slider-label">1 km</text>
      <slider
        class="slider"
        min="1"
        max="5"
        step="0.1"
        value="{{distance}}"
        activeColor="#6B4EAA"
        backgroundColor="#eee"
        block-size="24"
        bindchange="onDistanceChange"
      />
      <text class="slider-label">5 km</text>
    </view>
    <text class="distance-hint">{{t.distanceHintBefore}}{{ distance }}{{t.distanceHintAfter}}</text>
  </view>

  <view class="section card">
    <button class="btn primary big" disabled="{{!hasLocation}}" bindtap="onRandomTap">{{t.btnRandom}}</button>
  </view>

  <view wx:if="{{result}}" class="section card result">
    <text class="result-title">{{t.resultTitle}}</text>
    <text class="result-name">{{ result.name }}</text>
    <text wx:if="{{result.cuisine}}" class="result-cuisine">{{t.cuisineLabel}}{{ result.cuisine }}</text>
    <text wx:if="{{result.region && result.region !== '未知'}}" class="result-address-label">{{t.regionLabel}}</text>
    <text wx:if="{{result.region && result.region !== '未知'}}" class="result-address">{{ result.region }}</text>
    <block wx:if="{{result.address && result.address !== '未知'}}">
      <text class="result-address-label">{{t.addressLabel}}</text>
      <text class="result-address">{{ result.address }}</text>
    </block>
    <text wx:if="{{result.distance}}" class="result-distance">{{t.distanceAboutBefore}}{{ result.distance }}{{t.distanceAboutAfter}}</text>
  </view>

</view>
